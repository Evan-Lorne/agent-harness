# 模型：使用真实模型时填写 API Key。留空则使用 MockModel。
OPENAI_API_KEY=

# 与所选 OpenAI 兼容 API 对应的 Base URL。
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 可选：连续过载时切换的备用模型 ID。
FALLBACK_MODEL_ID=

# 可选：RAG Embedding。
ALIYUN_API_KEY=

# 可选：网络搜索（二选一或同时配置）。
TAVILY_API_KEY=
SERPER_API_KEY=

# 可选：飞书 Channel。
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# 可选：Supabase 示例 Plugin。
SUPABASE_URL=
SUPABASE_KEY=

# 可选：在 mcpServers 配置中引用时使用。
GITHUB_TOKEN=
